    // ── Main App ──
    function App() {
      const [mapCenter, setMapCenter] = useState([35.5, 138.7]);
      const [mapZoom, setMapZoom] = useState(8);
      const [allPoints, setAllPoints] = useState([]);
      const [animePopup, setAnimePopup] = useState(null);
      const [activeDay, setActiveDay] = useState(null);
      const [isLegendExpanded, setIsLegendExpanded] = useState(false); // NEW STATE FOR LEGEND TOGGLE

      // Fetch all Anitabi points
      useEffect(() => {
        const fetchPoints = async () => {
          const results = [];
          for (const anime of ANIME_LIST) {
            try {
              const res = await fetch(
                `https://api.anitabi.cn/bangumi/${anime.id}/points/detail?haveImage=true`,
                { signal: AbortSignal.timeout(8000) }
              );
              if (!res.ok) continue;
              const data = await res.json();
              if (Array.isArray(data)) {
                data.forEach(pt => {
                  if (pt.geo && pt.image) {
                    results.push({
                      ...pt,
                      animeId: anime.id,
                      animeName: anime.name,
                      animeCn: anime.nameCn,
                      animeColor: anime.color,
                      animeEmoji: anime.emoji,
                    });
                  }
                });
              }
            } catch { /* silently ignore */ }
          }
          setAllPoints(results);
        };
        fetchPoints();
      }, []);

      const handleDestinationClick = useCallback((lat, lng, day) => {
        setActiveDay(day);
        setMapCenter([lat, lng]);
        setMapZoom(14);

        // ─── 偵測半徑：1000m（方圓1公里）───
        const nearby = allPoints
          .map(pt => ({ point: pt, distance: haversine(lat, lng, pt.geo[0], pt.geo[1]) }))
          .filter(r => r.distance <= 1000)
          .sort((a, b) => a.distance - b.distance)
          .slice(0, 8);

        if (nearby.length > 0) setAnimePopup(nearby);
      }, [allPoints]);

      // Countdown
      useEffect(() => {
        const pad = n => (n < 10 ? '0' + n : '' + n);
        const tick = () => {
          const target = new Date('2026-07-08T00:55:00+08:00').getTime();
          const diff = target - Date.now();
          const el = id => document.getElementById(id);
          if (diff <= 0) {
            ['fuji-days','fuji-hours','fuji-mins','fuji-secs'].forEach(id => { const e = el(id); if (e) e.textContent = '00'; });
            return;
          }
          const days = Math.floor(diff / 86400000);
          const hours = Math.floor((diff % 86400000) / 3600000);
          const mins = Math.floor((diff % 3600000) / 60000);
          const secs = Math.floor((diff % 60000) / 1000);
          const d = el('fuji-days'); if (d) d.textContent = pad(days);
          const h = el('fuji-hours'); if (h) h.textContent = pad(hours);
          const m = el('fuji-mins'); if (m) m.textContent = pad(mins);
          const s = el('fuji-secs'); if (s) s.textContent = pad(secs);
        };
        tick();
        const t = setInterval(tick, 1000);
        return () => clearInterval(t);
      }, []);

      // Music bubble
      useEffect(() => {
        const audioRef = { current: null };
        const playingRef = { current: false };

        const setIcon = isPlaying => {
          const ico = document.getElementById('fuji-play-icon');
          const eq = document.getElementById('fuji-eq');
          if (!ico || !eq) return;
          if (isPlaying) {
            ico.innerHTML = '<rect x="1.5" y="1" width="2.8" height="8" rx="1" fill="white"/><rect x="5.7" y="1" width="2.8" height="8" rx="1" fill="white"/>';
            eq.classList.remove('paused');
          } else {
            ico.innerHTML = '<polygon points="2,1 9,5 2,9" fill="white"/>';
            eq.classList.add('paused');
          }
        };

        window['fujiTogglePlay'] = () => {
          if (!audioRef.current) {
            audioRef.current = new Audio('https://raw.githubusercontent.com/SamuelYuen0201/26inMt-Fuji/main/miku_hajimarinomirai_256kbps.mp3');
            audioRef.current.loop = true;
            audioRef.current.volume = 0.72;
          }
          const audio = audioRef.current;
          if (!playingRef.current) {
            const p = audio.play();
            if (p) p.then(() => { playingRef.current = true; setIcon(true); }).catch(() => {});
          } else {
            audio.pause(); playingRef.current = false; setIcon(false);
          }
        };
        setIcon(false);
      }, []);

      // Cursor canvas
      useEffect(() => {
        const canvas = document.getElementById('fuji-miku-canvas');
        if (!canvas) return;
        const ctx = canvas.getContext('2d');
        let running = true;
        const resize = () => { canvas.width = window.innerWidth; canvas.height = window.innerHeight; };
        resize();
        window.addEventListener('resize', resize);
        const particles = [];
        const mouse = { x: -999, y: -999, vx: 0, vy: 0 };
        const COLORS = ['rgba(57,197,187,', 'rgba(100,220,215,', 'rgba(200,240,238,', 'rgba(255,255,255,', 'rgba(180,240,235,'];
        const create = (x, y, vx, vy) => {
          const count = Math.min(Math.floor(Math.sqrt(vx*vx+vy*vy)*0.4)+1, 4);
          for (let i = 0; i < count; i++) {
            const a = Math.random()*Math.PI*2;
            const s = 1.5 + Math.random()*5;
            particles.push({ x:x+(Math.random()-0.5)*10, y:y+(Math.random()-0.5)*10, vx:Math.cos(a)*(0.3+Math.random()*1.5)+vx*0.08, vy:Math.sin(a)*(0.3+Math.random()*1.5)+vy*0.08-Math.random()*0.7, life:1, decay:0.012+Math.random()*0.018, size:s, maxSize:s, color:COLORS[Math.floor(Math.random()*COLORS.length)], rotation:Math.random()*Math.PI*2, rotSpeed:(Math.random()-0.5)*0.12 });
          }
        };
        let lastEmit = 0;
        const update = ts => {
          if (!running) return;
          ctx.clearRect(0,0,canvas.width,canvas.height);
          if (mouse.x > 0) {
            const g = ctx.createRadialGradient(mouse.x,mouse.y,0,mouse.x,mouse.y,20);
            g.addColorStop(0,'rgba(57,197,187,0.3)'); g.addColorStop(1,'rgba(57,197,187,0)');
            ctx.beginPath(); ctx.arc(mouse.x,mouse.y,20,0,Math.PI*2); ctx.fillStyle=g; ctx.fill();
          }
          const speed = Math.sqrt(mouse.vx**2+mouse.vy**2);
          if (ts-lastEmit>(speed>3?18:40)&&speed>0.5) { create(mouse.x,mouse.y,mouse.vx,mouse.vy); lastEmit=ts; }
          for (let i=particles.length-1;i>=0;i--) {
            const p=particles[i]; p.x+=p.vx; p.y+=p.vy; p.vy+=0.018; p.vx*=0.97; p.vy*=0.97;
            p.life-=p.decay; p.rotation+=p.rotSpeed; p.size=p.maxSize*p.life;
            if (p.life<=0){particles.splice(i,1);continue;}
            ctx.save(); ctx.translate(p.x,p.y); ctx.rotate(p.rotation); ctx.globalAlpha=p.life;
            ctx.fillStyle=p.color+p.life+')'; ctx.beginPath(); ctx.arc(0,0,p.size,0,Math.PI*2); ctx.fill(); ctx.restore();
          }
          requestAnimationFrame(update);
        };
        const onMove = e => { mouse.vx=e.clientX-mouse.x; mouse.vy=e.clientY-mouse.y; mouse.x=e.clientX; mouse.y=e.clientY; };
        const onTouch = e => { const t=e.touches[0]; mouse.vx=t.clientX-mouse.x; mouse.vy=t.clientY-mouse.y; mouse.x=t.clientX; mouse.y=t.clientY; };
        document.addEventListener('mousemove', onMove);
        document.addEventListener('touchmove', onTouch, { passive: true });
        requestAnimationFrame(update);
        return () => { running=false; window.removeEventListener('resize',resize); document.removeEventListener('mousemove',onMove); document.removeEventListener('touchmove',onTouch); };
      }, []);

      const dayColors = { 1:'#C8102E', 2:'#39C5BB', 3:'#C8102E', 4:'#C8102E', 5:'#39C5BB' };

      return (
        <>
          <MapBackground center={mapCenter} zoom={mapZoom} points={allPoints} />

          {animePopup && <AnimePopup results={animePopup} onClose={() => setAnimePopup(null)} />}

          {/* Map Legend (Collapsible) */}
          <div style={{
            position: 'fixed', top: '1rem', left: '1rem', zIndex: 100,
            background: 'rgba(255,255,255,0.92)', border: '1px solid #E0DDD6',
            borderRadius: '4px', 
            padding: '0.4rem 0.5rem', 
            boxShadow: '0 4px 20px rgba(0,0,0,0.1)', backdropFilter: 'blur(8px)',
            width: 'fit-content',
            transition: 'all 0.3s ease'
          }}>
            {/* Clickable Header */}
            <div 
              onClick={() => setIsLegendExpanded(!isLegendExpanded)}
              style={{ 
                display: 'flex', alignItems: 'center', justifyContent: 'space-between',
                cursor: 'pointer', gap: '0.8rem',
                marginBottom: isLegendExpanded ? '0.3rem' : '0' 
              }}
            >
              <div style={{ fontFamily: "'DM Mono',monospace", fontSize: '0.5rem', letterSpacing: '0.2em', color: '#888', textTransform: 'uppercase' }}>
                🗺️ 聖地巡禮 Map
              </div>
              <div style={{ 
                fontSize: '0.45rem', color: '#888', 
                transform: isLegendExpanded ? 'rotate(180deg)' : 'rotate(0deg)', 
                transition: 'transform 0.3s ease' 
              }}>
                ▼
              </div>
            </div>


<style>
/* ── SCOPED TO #fuji26 — prevents WordPress theme conflicts ── */

#fuji26 *, #fuji26 *::before, #fuji26 *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

#fuji26 {
  --red:   #C8102E;
  --miku:  #39C5BB;
  --miku2: #25A89F;
  --ink:   #1A1A1A;
  --gray:  #888888;
  --light: #F5F3EE;
  --white: #FFFFFF;
  --line:  #E0DDD6;
  background: #ffffff;
  color: #1A1A1A;
  font-family: 'Noto Serif JP', serif;
  font-weight: 300;
  line-height: 1.8;
  overflow-x: hidden;
  max-width: 100%;
}

/* ══════════════════════════════════
   KEYFRAMES
══════════════════════════════════ */
@keyframes fuji-fadeUp {
  from { opacity: 0; transform: translateY(28px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes fuji-fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}
@keyframes fuji-slideRight {
  from { opacity: 0; transform: translateX(-18px) scale(0.98); filter: blur(2px); }
  to   { opacity: 1; transform: translateX(0)     scale(1);    filter: blur(0); }
}
@keyframes fuji-pulse {
  0%,100% { transform: translate(-50%,-50%) scale(1);   opacity: 1; }
  50%      { transform: translate(-50%,-50%) scale(1.05); opacity: 0.55; }
}
@keyframes fuji-scrollLine {
  0%   { transform: scaleY(0); transform-origin: top; }
  50%  { transform: scaleY(1); transform-origin: top; }
  51%  { transform: scaleY(1); transform-origin: bottom; }
  100% { transform: scaleY(0); transform-origin: bottom; }
}
/* Dot glow pulse for major stops */
@keyframes fuji-dotGlow {
  0%,100% { box-shadow: 0 0 0 0 rgba(57,197,187,0.55); }
  50%      { box-shadow: 0 0 0 8px rgba(57,197,187,0); }
}
/* Floating particles */
@keyframes fuji-float {
  0%   { transform: translateY(0)   rotate(0deg);   opacity: 0; }
  10%  { opacity: 1; }
  90%  { opacity: 0.6; }
  100% { transform: translateY(-90vh) rotate(360deg); opacity: 0; }
}
/* Musical note float */
@keyframes fuji-noteFloat {
  0%   { transform: translateY(0) rotate(-10deg); opacity: 0; }
  15%  { opacity: 0.55; }
  85%  { opacity: 0.3; }
  100% { transform: translateY(-80px) rotate(12deg); opacity: 0; }
}
/* Shimmer sweep */
@keyframes fuji-shimmer {
  0%   { background-position: -200% center; }
  100% { background-position: 200% center; }
}
/* Miku bubble equalizer bars */
@keyframes fuji-eq1 { 0%,100%{height:4px}  25%{height:14px} 60%{height:8px}  }
@keyframes fuji-eq2 { 0%,100%{height:10px} 40%{height:4px}  70%{height:16px} }
@keyframes fuji-eq3 { 0%,100%{height:7px}  30%{height:18px} 65%{height:5px}  }
@keyframes fuji-eq4 { 0%,100%{height:14px} 20%{height:5px}  55%{height:12px} }
@keyframes fuji-eq5 { 0%,100%{height:5px}  45%{height:15px} 75%{height:8px}  }
/* Bubble entrance */
@keyframes fuji-bubbleIn {
  from { opacity: 0; transform: translateY(20px) scale(0.9); }
  to   { opacity: 1; transform: translateY(0)    scale(1); }
}
/* Twin-tail gentle sway */
@keyframes fuji-sway {
  0%,100% { transform: rotate(-1deg); }
  50%     { transform: rotate(1.5deg); }
}
/* Number count-up flash */
@keyframes fuji-numFlash {
  0%  { color: #39C5BB; }
  100%{ color: #1A1A1A; }
}
/* Card lift */
@keyframes fuji-cardIn {
  from { opacity: 0; transform: translateY(22px) scale(0.97); }
  to   { opacity: 1; transform: translateY(0)    scale(1); }
}


/* ══════════════════════════════════
   HERO
══════════════════════════════════ */
#fuji26 .f-hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 4rem 2rem 6rem;
  border-bottom: 1px solid #E0DDD6;
  overflow: hidden;
  background: #ffffff;
  text-align: center;
}

/* Floating particles */
#fuji26 .f-particle {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  animation: fuji-float linear infinite;
}

#fuji26 .f-circle {
  position: absolute;
  border-radius: 50%;
  border: 1px solid rgba(200,16,46,0.07);
  top: 50%; left: 50%;
  animation: fuji-pulse 6s ease-in-out infinite;
  pointer-events: none;
}
#fuji26 .f-circle:nth-child(1) { width: 500px; height: 500px; }
#fuji26 .f-circle:nth-child(2) { width: 700px; height: 700px; animation-delay: 1s; border-color: rgba(200,16,46,0.04); }
#fuji26 .f-circle:nth-child(3) { width: 900px; height: 900px; animation-delay: 2s; border-color: rgba(200,16,46,0.025); }
/* Miku-teal circle */
#fuji26 .f-circle.miku { border-color: rgba(57,197,187,0.08); animation-duration: 8s; }

#fuji26 .f-fuji-svg {
  position: absolute;
  bottom: 0; left: 50%;
  transform: translateX(-50%);
  width: 100%; max-width: 860px;
  opacity: 0.04;
  pointer-events: none;
}

/* Miku twin-tail silhouette watermark */
#fuji26 .f-miku-watermark {
  position: absolute;
  bottom: 3rem; right: 3rem;
  opacity: 0.055;
  pointer-events: none;
  animation: fuji-sway 5s ease-in-out infinite;
  transform-origin: bottom center;
}

#fuji26 .f-hero-label {
  font-family: 'DM Mono', monospace;
  font-size: 0.7rem;
  letter-spacing: 0.32em;
  color: #C8102E;
  text-transform: uppercase;
  position: relative; z-index: 1;
  animation: fuji-fadeUp 0.7s 0.1s ease both;
  margin-bottom: 1.2rem;
}

#fuji26 .f-hero-title {
  font-family: 'Shippori Mincho', serif;
  font-size: clamp(3.2rem, 11vw, 7.5rem);
  font-weight: 700;
  letter-spacing: -0.02em;
  line-height: 1;
  position: relative; z-index: 1;
  animation: fuji-fadeUp 0.7s 0.25s ease both;
}
#fuji26 .f-hero-title span { color: #C8102E; }
/* Miku teal underline on Mt. */
#fuji26 .f-hero-title span::after {
  content: '';
  display: block;
  height: 3px;
  background: linear-gradient(90deg, #39C5BB, transparent);
  margin-top: 2px;
  border-radius: 2px;
  animation: fuji-fadeIn 1s 1s ease both;
}

#fuji26 .f-hero-sub {
  margin-top: 1rem;
  font-size: 0.95rem;
  color: #888;
  letter-spacing: 0.28em;
  position: relative; z-index: 1;
  animation: fuji-fadeUp 0.7s 0.4s ease both;
}

#fuji26 .f-hero-date {
  margin-top: 1.2rem;
  font-family: 'DM Mono', monospace;
  font-size: 0.8rem;
  color: #1A1A1A;
  letter-spacing: 0.15em;
  position: relative; z-index: 1;
  animation: fuji-fadeUp 0.7s 0.55s ease both;
}

/* Miku tag badge */
#fuji26 .f-miku-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  margin-top: 1rem;
  padding: 0.3rem 0.8rem;
  border: 1px solid rgba(57,197,187,0.35);
  border-radius: 2px;
  font-family: 'DM Mono', monospace;
  font-size: 0.6rem;
  letter-spacing: 0.25em;
  color: #39C5BB;
  position: relative; z-index: 1;
  animation: fuji-fadeUp 0.7s 0.65s ease both;
  background: rgba(57,197,187,0.04);
}
#fuji26 .f-miku-badge svg { flex-shrink: 0; }

/* ── COUNTDOWN ── */
#fuji26 .f-countdown-wrap {
  margin-top: 2.5rem;
  position: relative; z-index: 1;
  animation: fuji-fadeUp 0.7s 0.7s ease both;
}
#fuji26 .f-cd-label {
  font-family: 'DM Mono', monospace;
  font-size: 0.6rem;
  letter-spacing: 0.38em;
  color: #888;
  text-transform: uppercase;
  margin-bottom: 0.9rem;
}
#fuji26 .f-countdown {
  display: flex;
  gap: 1.2rem;
  align-items: flex-end;
  justify-content: center;
  flex-wrap: wrap;
}
#fuji26 .f-cb {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.25rem;
}
#fuji26 .f-num {
  font-family: 'Shippori Mincho', serif;
  font-size: clamp(2.2rem, 7vw, 4rem);
  font-weight: 700;
  line-height: 1;
  color: #C8102E;
  min-width: 2ch;
  text-align: center;
  transition: color 0.3s;
}
#fuji26 .f-num.tick { animation: fuji-numFlash 0.3s ease both; }
#fuji26 .f-unit {
  font-family: 'DM Mono', monospace;
  font-size: 0.55rem;
  letter-spacing: 0.22em;
  color: #888;
  text-transform: uppercase;
}
#fuji26 .f-sep {
  font-family: 'Shippori Mincho', serif;
  font-size: 2.5rem;
  color: #E0DDD6;
  line-height: 1;
  padding-bottom: 0.4rem;
}

/* ── SCROLL INDICATOR ── */
#fuji26 .f-scroll {
  position: absolute;
  bottom: 1.8rem; left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.4rem;
  font-family: 'DM Mono', monospace;
  font-size: 0.52rem;
  letter-spacing: 0.35em;
  color: #888;
  text-transform: uppercase;
  animation: fuji-fadeUp 1s 1.3s ease both;
  z-index: 1;
}
#fuji26 .f-scroll-line {
  width: 1px; height: 36px;
  background: linear-gradient(to bottom, #39C5BB, transparent);
  animation: fuji-scrollLine 1.6s ease-in-out infinite;
}

/* ── PATTERN BORDER ── */
#fuji26 .f-jp-border {
  height: 4px;
  background: repeating-linear-gradient(90deg,
    #C8102E 0, #C8102E 6px,
    #39C5BB 6px, #39C5BB 10px,
    transparent 10px, transparent 18px);
  opacity: 0.18;
}

/* ── SECTION LABEL ── */
#fuji26 .f-section-label {
  font-family: 'DM Mono', monospace;
  font-size: 0.62rem;
  letter-spacing: 0.42em;
  color: #C8102E;
  text-transform: uppercase;
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 2rem;
  position: relative;
  overflow: hidden;
}
#fuji26 .f-section-label::after {
  content: '';
  flex: 1;
  height: 1px;
  background: linear-gradient(90deg, #E0DDD6, #39C5BB22);
}
/* Animated underline sweep on label text */
#fuji26 .f-section-label::before {
  content: '';
  position: absolute;
  bottom: -2px; left: 0;
  width: 40px; height: 1px;
  background: #39C5BB;
  animation: fuji-shimmer 3s ease infinite;
  opacity: 0.5;
}

/* ── NOTICES ── */
#fuji26 .f-notices {
  background: #F5F3EE;
  padding: 4rem 2rem;
  border-bottom: 1px solid #E0DDD6;
}
#fuji26 .f-notices-inner { max-width: 900px; margin: 0 auto; }
#fuji26 .f-notices-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
  gap: 1.4rem;
}

#fuji26 .f-ncard {
  background: #ffffff;
  border: 1px solid #E0DDD6;
  padding: 1.4rem;
  position: relative;
  animation: fuji-cardIn 0.6s ease both;
  transition: transform 0.25s ease, box-shadow 0.25s ease;
  overflow: hidden;
}
#fuji26 .f-ncard:nth-child(1) { animation-delay: 0.1s; }
#fuji26 .f-ncard:nth-child(2) { animation-delay: 0.22s; }
#fuji26 .f-ncard:nth-child(3) { animation-delay: 0.34s; }

#fuji26 .f-ncard:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 24px rgba(0,0,0,0.07);
}
/* shimmer on hover */
#fuji26 .f-ncard::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,0.55) 50%, transparent 60%);
  background-size: 200% 100%;
  opacity: 0;
  transition: opacity 0.3s;
}
#fuji26 .f-ncard:hover::after {
  opacity: 1;
  animation: fuji-shimmer 0.6s ease;
}

#fuji26 .f-ncard::before {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 3px; height: 100%;
  background: linear-gradient(to bottom, #C8102E, #39C5BB);
}
#fuji26 .f-ndate {
  font-family: 'DM Mono', monospace;
  font-size: 0.72rem;
  color: #C8102E;
  letter-spacing: 0.1em;
  margin-bottom: 0.4rem;
}
#fuji26 .f-ntitle {
  font-family: 'Shippori Mincho', serif;
  font-size: 1rem;
  font-weight: 700;
  margin-bottom: 0.3rem;
  color: #1A1A1A;
}
#fuji26 .f-ndesc {
  font-size: 0.78rem;
  color: #888;
  line-height: 1.6;
}

/* ── TIMELINE SECTION ── */
#fuji26 .f-tl-section {
  padding: 5rem 2rem;
  max-width: 1000px;
  margin: 0 auto;
}

/* ── DAY BLOCK ── */
#fuji26 .f-day {
  margin-bottom: 5rem;
  animation: fuji-fadeUp 0.7s ease both;
}
#fuji26 .f-day:nth-child(2) { animation-delay: 0.05s; }
#fuji26 .f-day:nth-child(3) { animation-delay: 0.1s; }
#fuji26 .f-day:nth-child(4) { animation-delay: 0.15s; }
#fuji26 .f-day:nth-child(5) { animation-delay: 0.2s; }
#fuji26 .f-day:nth-child(6) { animation-delay: 0.25s; }

#fuji26 .f-day-header {
  display: flex;
  align-items: flex-end;
  gap: 1.5rem;
  margin-bottom: 2rem;
  padding-bottom: 1.2rem;
  border-bottom: 1px solid #E0DDD6;
  position: relative;
}
/* Teal accent line on day header bottom */
#fuji26 .f-day-header::after {
  content: '';
  position: absolute;
  bottom: -1px; left: 0;
  width: 48px; height: 2px;
  background: #39C5BB;
  border-radius: 2px;
}

#fuji26 .f-day-num {
  font-family: 'Shippori Mincho', serif;
  font-size: clamp(3.5rem, 9vw, 6rem);
  font-weight: 700;
  line-height: 1;
  color: #E0DDD6;
  letter-spacing: -0.03em;
  transition: color 0.3s;
}
#fuji26 .f-day:hover .f-day-num { color: rgba(57,197,187,0.25); }

#fuji26 .f-day-info { flex: 1; }
#fuji26 .f-day-date {
  font-family: 'DM Mono', monospace;
  font-size: 0.68rem;
  color: #C8102E;
  letter-spacing: 0.25em;
  margin-bottom: 0.2rem;
}
#fuji26 .f-day-theme {
  font-family: 'Shippori Mincho', serif;
  font-size: 1.3rem;
  font-weight: 700;
  color: #1A1A1A;
}

/* ── TIMELINE ── */
#fuji26 .f-timeline {
  position: relative;
  padding-left: 2.2rem;
}

/* Animated flowing line using SVG-like gradient + pseudo animation */
#fuji26 .f-timeline::before {
  content: '';
  position: absolute;
  left: 5px; top: 8px; bottom: 0;
  width: 2px;
  background: linear-gradient(
    to bottom,
    #C8102E 0%,
    #39C5BB 35%,
    rgba(57,197,187,0.4) 65%,
    rgba(224,221,214,0.3) 100%
  );
  border-radius: 2px;
  animation: fuji-lineFlow 4s ease-in-out infinite;
}
/* Secondary shimmer layer on the line */
#fuji26 .f-timeline::after {
  content: '';
  position: absolute;
  left: 5px; top: 8px; bottom: 0;
  width: 2px;
  background: linear-gradient(
    to bottom,
    transparent 0%,
    rgba(255,255,255,0.8) 40%,
    transparent 55%
  );
  background-size: 100% 60px;
  animation: fuji-lineScan 2.5s linear infinite;
  pointer-events: none;
}
@keyframes fuji-lineFlow {
  0%,100% { opacity: 1; }
  50%      { opacity: 0.7; }
}
@keyframes fuji-lineScan {
  0%   { background-position: 0 -60px; }
  100% { background-position: 0 100%; }
}

/* Each tl-item */
#fuji26 .f-tl-item {
  position: relative;
  margin-bottom: 1.8rem;
  animation: fuji-slideRight 0.5s ease both;
  padding: 0.6rem 0.8rem;
  border-radius: 3px;
  transition: background 0.25s ease, transform 0.2s ease;
  border-left: 2px solid transparent;
}
#fuji26 .f-tl-item:hover {
  background: rgba(57,197,187,0.05);
  border-left-color: rgba(57,197,187,0.3);
  transform: translateX(3px);
}

/* Connector segment between dots - decorative tick mark */
#fuji26 .f-tl-item::after {
  content: '';
  position: absolute;
  left: calc(-2.2rem + 5px);
  top: 50%;
  width: 10px;
  height: 1px;
  background: linear-gradient(to right, #39C5BB, transparent);
  opacity: 0;
  transition: opacity 0.25s;
}
#fuji26 .f-tl-item:hover::after { opacity: 0.6; }

#fuji26 .f-tl-item:nth-child(1)  { animation-delay: 0.05s; }
#fuji26 .f-tl-item:nth-child(2)  { animation-delay: 0.10s; }
#fuji26 .f-tl-item:nth-child(3)  { animation-delay: 0.15s; }
#fuji26 .f-tl-item:nth-child(4)  { animation-delay: 0.20s; }
#fuji26 .f-tl-item:nth-child(5)  { animation-delay: 0.25s; }
#fuji26 .f-tl-item:nth-child(6)  { animation-delay: 0.30s; }
#fuji26 .f-tl-item:nth-child(7)  { animation-delay: 0.35s; }
#fuji26 .f-tl-item:nth-child(8)  { animation-delay: 0.40s; }
#fuji26 .f-tl-item:nth-child(9)  { animation-delay: 0.45s; }
#fuji26 .f-tl-item:nth-child(10) { animation-delay: 0.50s; }
#fuji26 .f-tl-item:nth-child(11) { animation-delay: 0.55s; }
#fuji26 .f-tl-item:nth-child(12) { animation-delay: 0.60s; }

#fuji26 .f-dot {
  position: absolute;
  left: calc(-2.2rem - 1px);
  top: 11px;
  width: 12px; height: 12px;
  border-radius: 50%;
  background: #ffffff;
  border: 2px solid #C8102E;
  transition: background 0.2s, transform 0.25s, border-color 0.2s;
}
#fuji26 .f-dot.major {
  background: #C8102E;
  width: 14px; height: 14px;
  top: 10px;
  animation: fuji-dotGlow 2.5s ease-in-out infinite;
}
#fuji26 .f-tl-item:hover .f-dot {
  background: #39C5BB;
  border-color: #39C5BB;
  transform: scale(1.35);
}
#fuji26 .f-tl-item:hover .f-dot.major {
  background: #39C5BB;
  border-color: #39C5BB;
}

#fuji26 .f-time {
  font-family: 'DM Mono', monospace;
  font-size: 0.63rem;
  color: #888;
  letter-spacing: 0.1em;
  margin-bottom: 0.15rem;
}
#fuji26 .f-name {
  font-family: 'Shippori Mincho', serif;
  font-size: 0.98rem;
  font-weight: 700;
  color: #1A1A1A;
  margin-bottom: 0.15rem;
  transition: color 0.2s;
}
#fuji26 .f-tl-item:hover .f-name { color: #1A1A1A; }
#fuji26 .f-desc {
  font-size: 0.77rem;
  color: #888;
  line-height: 1.65;
}
#fuji26 .f-tag {
  display: inline-block;
  font-family: 'DM Mono', monospace;
  font-size: 0.56rem;
  letter-spacing: 0.15em;
  padding: 0.12rem 0.45rem;
  border: 1px solid #E0DDD6;
  color: #888;
  margin-top: 0.3rem;
  margin-right: 0.3rem;
  text-transform: uppercase;
  transition: border-color 0.2s, color 0.2s;
}
#fuji26 .f-tl-item:hover .f-tag { border-color: rgba(57,197,187,0.3); }
#fuji26 .f-tag.red {
  border-color: #C8102E;
  color: #C8102E;
}
#fuji26 .f-tl-item:hover .f-tag.red { border-color: #C8102E; }

/* ── BUDGET ── */
#fuji26 .f-budget {
  background: #F5F3EE;
  padding: 5rem 2rem;
  border-top: 1px solid #E0DDD6;
}
#fuji26 .f-budget-inner { max-width: 900px; margin: 0 auto; }
#fuji26 .f-budget-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(175px, 1fr));
  gap: 1.4rem;
}
#fuji26 .f-bcard {
  background: #ffffff;
  border: 1px solid #E0DDD6;
  padding: 1.4rem;
  animation: fuji-cardIn 0.6s ease both;
  transition: transform 0.22s ease, box-shadow 0.22s ease;
  cursor: default;
  overflow: hidden;
  position: relative;
}
#fuji26 .f-bcard::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(105deg, transparent 38%, rgba(57,197,187,0.08) 50%, transparent 62%);
  background-size: 200% 100%;
  opacity: 0;
  transition: opacity 0.3s;
}
#fuji26 .f-bcard:hover::after {
  opacity: 1;
  animation: fuji-shimmer 0.7s ease;
}
#fuji26 .f-bcard:hover {
  transform: translateY(-4px) rotate(0.4deg);

    // ── MapBackground ──
    function MapBackground({ center, zoom, points }) {
      const mapRef = useRef(null);
      const mapElRef = useRef(null);
      const markersRef = useRef(null);

      useEffect(() => {
        if (!mapElRef.current || mapRef.current) return;
        const map = L.map(mapElRef.current, {
          center, zoom,
          zoomControl: false, attributionControl: false,
          dragging: false, scrollWheelZoom: false,
          doubleClickZoom: false, touchZoom: false, keyboard: false,
        });
        L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
          attribution: '', subdomains: 'abcd', maxZoom: 19,
        }).addTo(map);
        markersRef.current = L.layerGroup().addTo(map);
        mapRef.current = map;
        return () => { map.remove(); mapRef.current = null; };
      }, []);

      useEffect(() => {
        if (!mapRef.current) return;
        mapRef.current.flyTo(center, zoom, { animate: true, duration: 1.2 });
      }, [center, zoom]);

      useEffect(() => {
        if (!mapRef.current || !markersRef.current) return;
        markersRef.current.clearLayers();
        points.forEach(pt => {
          const svgIcon = `<svg width="24" height="24" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="8" fill="${pt.animeColor}" fill-opacity="0.85" stroke="white" stroke-width="2.5"/><circle cx="12" cy="12" r="3" fill="white"/></svg>`;
          const icon = L.divIcon({ className: '', html: svgIcon, iconSize: [24, 24], iconAnchor: [12, 12] });
          const marker = L.marker([pt.geo[0], pt.geo[1]], { icon });
          const label = pt.cn || pt.name;
          marker.bindTooltip(`<span style="font-family:'DM Mono',monospace;font-size:0.65rem;color:${pt.animeColor}">${pt.animeEmoji} ${label}</span>`, {
            permanent: false, direction: 'top', offset: [0, -10],
          });
          markersRef.current.addLayer(marker);
        });
      }, [points]);

      return (
        <div ref={mapElRef} style={{
          position: 'fixed', inset: 0, zIndex: 0,
          opacity: 0.22, pointerEvents: 'none', filter: 'saturate(0.7)',
        }} />
      );
    }


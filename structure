<!-- ═══════════════ MIKU CURSOR CANVAS ═══════════════ -->

<canvas id="fuji-miku-canvas" style="
position:fixed;
top:0;left:0;
width:100%;height:100%;
pointer-events:none;
z-index:99998;
"></canvas>

<script>
/* ── COUNTDOWN ── */
(function() {
  function pad(n) { return n < 10 ? '0' + n : '' + n; }
  function tick() {
    var target = new Date('2026-07-08T00:55:00+08:00').getTime();
    var now    = Date.now();
    var diff   = target - now;
    var d = document;
    if (diff <= 0) {
      ['fuji-days','fuji-hours','fuji-mins','fuji-secs'].forEach(function(id){
        var el = d.getElementById(id); if(el) el.textContent = '00';
      });
      return;
    }
    var days  = Math.floor(diff / 86400000);
    var hours = Math.floor((diff % 86400000) / 3600000);
    var mins  = Math.floor((diff % 3600000)  / 60000);
    var secs  = Math.floor((diff % 60000)    / 1000);
    var el;
    el = d.getElementById('fuji-days');  if(el) el.textContent = pad(days);
    el = d.getElementById('fuji-hours'); if(el) el.textContent = pad(hours);
    el = d.getElementById('fuji-mins');  if(el) el.textContent = pad(mins);
    el = d.getElementById('fuji-secs');  if(el) el.textContent = pad(secs);
  }
  tick();
  setInterval(tick, 1000);
})();

/* ── MUSIC BUBBLE ── */
var fujiPlaying = true;
function fujiTogglePlay() {
  fujiPlaying = !fujiPlaying;
  var eq  = document.getElementById('fuji-eq');
  var ico = document.getElementById('fuji-play-icon');
  if (fujiPlaying) {
    eq.classList.remove('paused');
    ico.innerHTML = '<rect x="2" y="1" width="2.5" height="8" rx="1"/><rect x="5.5" y="1" width="2.5" height="8" rx="1"/>';
  } else {
    eq.classList.add('paused');
    ico.innerHTML = '<polygon points="2,1 9,5 2,9"/>';
  }
}
/* Set initial state to paused icon since we can't play audio */
(function(){
  var ico = document.getElementById('fuji-play-icon');
  if(ico) ico.innerHTML = '<rect x="2" y="1" width="2.5" height="8" rx="1" fill="white"/><rect x="5.5" y="1" width="2.5" height="8" rx="1" fill="white"/>';
})();

/* ── MIKU CURSOR PARTICLE SYSTEM ── */
(function() {
  var canvas = document.getElementById('fuji-miku-canvas');
  if (!canvas) return;
  var ctx = canvas.getContext('2d');

  function resize() {
    canvas.width  = window.innerWidth;
    canvas.height = window.innerHeight;
  }
  resize();
  window.addEventListener('resize', resize);

  /* Particle pool */
  var particles = [];
  var mouse = { x: -999, y: -999, vx: 0, vy: 0, px: -999, py: -999 };

  /* Miku color palette */
  var COLORS = [
    'rgba(57,197,187,',   /* miku teal */
    'rgba(25,168,159,',   /* deep teal */
    'rgba(100,220,215,',  /* light teal */
    'rgba(200,240,238,',  /* pale teal */
    'rgba(255,255,255,',  /* white */
    'rgba(180,240,235,',  /* icy */
  ];

  /* Particle shapes */
  var SHAPES = ['circle','petal','crystal','star','ring'];

  function randomBetween(a, b) { return a + Math.random() * (b - a); }

  function createParticle(x, y, vx, vy) {
    var speed = Math.sqrt(vx * vx + vy * vy);
    var count = Math.min(Math.floor(speed * 0.4) + 1, 5);
    for (var i = 0; i < count; i++) {
      var angle  = Math.random() * Math.PI * 2;
      var radius = randomBetween(30, 90);
      var col    = COLORS[Math.floor(Math.random() * COLORS.length)];
      var shape  = SHAPES[Math.floor(Math.random() * SHAPES.length)];
      var size   = randomBetween(2, 7);
      particles.push({
        x: x + randomBetween(-8, 8),
        y: y + randomBetween(-8, 8),
        vx: Math.cos(angle) * randomBetween(0.3, 1.8) + vx * 0.08,
        vy: Math.sin(angle) * randomBetween(0.3, 1.8) + vy * 0.08 - randomBetween(0.2, 0.8),
        life: 1.0,
        decay: randomBetween(0.012, 0.028),
        size: size,
        maxSize: size,
        color: col,
        shape: shape,
        rotation: Math.random() * Math.PI * 2,
        rotSpeed: randomBetween(-0.06, 0.06),
        twinkle: Math.random() < 0.3,
        twinklePhase: Math.random() * Math.PI * 2,
        trail: [],
      });
    }
  }

  function drawPetal(ctx, size) {
    ctx.beginPath();
    ctx.moveTo(0, -size);
    ctx.bezierCurveTo(size * 0.6, -size * 0.5, size * 0.6, size * 0.5, 0, size * 0.3);
    ctx.bezierCurveTo(-size * 0.6, size * 0.5, -size * 0.6, -size * 0.5, 0, -size);
    ctx.fill();
  }

  function drawCrystal(ctx, size) {
    ctx.beginPath();
    ctx.moveTo(0, -size);
    ctx.lineTo(size * 0.5, 0);
    ctx.lineTo(0, size);
    ctx.lineTo(-size * 0.5, 0);
    ctx.closePath();
    ctx.fill();
    /* inner shine */
    ctx.globalAlpha *= 0.4;
    ctx.fillStyle = 'rgba(255,255,255,1)';
    ctx.beginPath();
    ctx.moveTo(0, -size * 0.5);
    ctx.lineTo(size * 0.2, 0);
    ctx.lineTo(0, size * 0.5);
    ctx.lineTo(-size * 0.2, 0);
    ctx.closePath();
    ctx.fill();
  }

  function drawStar(ctx, size, points) {
    points = points || 5;
    var inner = size * 0.45;
    ctx.beginPath();
    for (var i = 0; i < points * 2; i++) {
      var r = i % 2 === 0 ? size : inner;
      var a = (i / points) * Math.PI - Math.PI / 2;
      if (i === 0) ctx.moveTo(Math.cos(a) * r, Math.sin(a) * r);
      else         ctx.lineTo(Math.cos(a) * r, Math.sin(a) * r);
    }
    ctx.closePath();
    ctx.fill();
  }

  function drawRing(ctx, size) {
    ctx.beginPath();
    ctx.arc(0, 0, size, 0, Math.PI * 2);
    ctx.stroke();
    ctx.lineWidth = size * 0.25;
  }

  function drawParticle(p) {
    var alpha = p.life;
    if (p.twinkle) {
      alpha *= 0.65 + 0.35 * Math.sin(p.twinklePhase + performance.now() * 0.005);
    }
    if (alpha <= 0) return;

    /* Draw short trail */
    if (p.trail.length > 1) {
      for (var t = 1; t < p.trail.length; t++) {
        var ta = (t / p.trail.length) * alpha * 0.25;
        ctx.strokeStyle = p.color + ta + ')';
        ctx.lineWidth = p.size * (t / p.trail.length) * 0.5;
        ctx.beginPath();
        ctx.moveTo(p.trail[t-1].x, p.trail[t-1].y);
        ctx.lineTo(p.trail[t].x, p.trail[t].y);
        ctx.stroke();
      }
    }

    ctx.save();
    ctx.translate(p.x, p.y);
    ctx.rotate(p.rotation);
    ctx.globalAlpha = alpha;
    ctx.fillStyle   = p.color + alpha + ')';
    ctx.strokeStyle = p.color + alpha + ')';
    ctx.lineWidth   = 1.2;

    switch (p.shape) {
      case 'circle':
        ctx.beginPath();
        ctx.arc(0, 0, p.size, 0, Math.PI * 2);
        ctx.fill();
        break;
      case 'petal':
        drawPetal(ctx, p.size);
        break;
      case 'crystal':
        drawCrystal(ctx, p.size);
        break;
      case 'star':
        drawStar(ctx, p.size);
        break;
      case 'ring':
        ctx.beginPath();
        ctx.arc(0, 0, p.size, 0, Math.PI * 2);
        ctx.lineWidth = Math.max(1, p.size * 0.3);
        ctx.stroke();
        break;
    }
    ctx.restore();
  }

  /* Cursor glow dot */
  function drawCursorGlow(x, y) {
    if (x < 0) return;
    var grad = ctx.createRadialGradient(x, y, 0, x, y, 18);
    grad.addColorStop(0,   'rgba(57,197,187,0.35)');
    grad.addColorStop(0.5, 'rgba(57,197,187,0.1)');
    grad.addColorStop(1,   'rgba(57,197,187,0)');
    ctx.beginPath();
    ctx.arc(x, y, 18, 0, Math.PI * 2);
    ctx.fillStyle = grad;
    ctx.fill();
  }

  var lastEmit = 0;
  function update(ts) {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    /* Cursor glow */
    drawCursorGlow(mouse.x, mouse.y);

    /* Throttle emission */
    var speed = Math.sqrt(mouse.vx * mouse.vx + mouse.vy * mouse.vy);
    if (ts - lastEmit > (speed > 3 ? 16 : 35) && speed > 0.5) {
      createParticle(mouse.x, mouse.y, mouse.vx, mouse.vy);
      lastEmit = ts;
    }

    for (var i = particles.length - 1; i >= 0; i--) {
      var p = particles[i];
      p.trail.push({ x: p.x, y: p.y });
      if (p.trail.length > 6) p.trail.shift();
      p.x        += p.vx;
      p.y        += p.vy;
      p.vy       += 0.018; /* gentle gravity */
      p.vx       *= 0.97;
      p.vy       *= 0.97;
      p.life     -= p.decay;
      p.rotation += p.rotSpeed;
      p.size      = p.maxSize * p.life;
      drawParticle(p);
      if (p.life <= 0) particles.splice(i, 1);
    }

    requestAnimationFrame(update);
  }

  /* Track mouse */
  document.addEventListener('mousemove', function(e) {
    mouse.vx = e.clientX - mouse.x;
    mouse.vy = e.clientY - mouse.y;
    mouse.x  = e.clientX;
    mouse.y  = e.clientY;
  });

  /* Touch support */
  document.addEventListener('touchmove', function(e) {
    var t = e.touches[0];
    mouse.vx = t.clientX - mouse.x;
    mouse.vy = t.clientY - mouse.y;
    mouse.x  = t.clientX;
    mouse.y  = t.clientY;
  }, { passive: true });

  requestAnimationFrame(update);
})();
</script>

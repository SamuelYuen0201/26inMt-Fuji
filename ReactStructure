<!doctype html>
<html lang="zh-Hant">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>26inMt.Fuji · 2026 Japan Expedition</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400;700&family=Shippori+Mincho:wght@400;700&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin=""/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{background:#F5F3EE;overflow-x:hidden}

@keyframes fuji-fadeUp{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:translateY(0)}}
@keyframes fuji-fadeIn{from{opacity:0}to{opacity:1}}
@keyframes fuji-slideRight{from{opacity:0;transform:translateX(-18px) scale(0.98);filter:blur(2px)}to{opacity:1;transform:translateX(0) scale(1);filter:blur(0)}}
@keyframes fuji-pulse{0%,100%{transform:translate(-50%,-50%) scale(1);opacity:1}50%{transform:translate(-50%,-50%) scale(1.05);opacity:0.55}}
@keyframes fuji-scrollLine{0%{transform:scaleY(0);transform-origin:top}50%{transform:scaleY(1);transform-origin:top}51%{transform:scaleY(1);transform-origin:bottom}100%{transform:scaleY(0);transform-origin:bottom}}
@keyframes fuji-dotGlow{0%,100%{box-shadow:0 0 0 0 rgba(57,197,187,.55)}50%{box-shadow:0 0 0 8px rgba(57,197,187,0)}}
@keyframes fuji-float{0%{transform:translateY(0) rotate(0deg);opacity:0}10%{opacity:1}90%{opacity:.6}100%{transform:translateY(-90vh) rotate(360deg);opacity:0}}
@keyframes fuji-shimmer{0%{background-position:-200% center}100%{background-position:200% center}}
@keyframes fuji-eq1{0%,100%{height:4px}25%{height:14px}60%{height:8px}}
@keyframes fuji-eq2{0%,100%{height:10px}40%{height:4px}70%{height:16px}}
@keyframes fuji-eq3{0%,100%{height:7px}30%{height:18px}65%{height:5px}}
@keyframes fuji-eq4{0%,100%{height:14px}20%{height:5px}55%{height:12px}}
@keyframes fuji-eq5{0%,100%{height:5px}45%{height:15px}75%{height:8px}}
@keyframes fuji-bubbleIn{from{opacity:0;transform:translateY(20px) scale(0.9)}to{opacity:1;transform:translateY(0) scale(1)}}
@keyframes fuji-sway{0%,100%{transform:rotate(-1deg)}50%{transform:rotate(1.5deg)}}
@keyframes fuji-cardIn{from{opacity:0;transform:translateY(22px) scale(0.97)}to{opacity:1;transform:translateY(0) scale(1)}}
@keyframes fuji-lineFlow{0%,100%{opacity:1}50%{opacity:.7}}
@keyframes fuji-lineScan{0%{background-position:0 -60px}100%{background-position:0 100%}}
@keyframes fuji-spin{to{transform:rotate(360deg)}}

#fuji26{
  --red:#C8102E;--miku:#39C5BB;--miku2:#25A89F;--ink:#1A1A1A;
  --gray:#888;--light:#F5F3EE;--white:#fff;--line:#E0DDD6;
  background:rgba(255,255,255,.88);color:#1A1A1A;
  font-family:'Noto Serif JP',serif;font-weight:300;line-height:1.8;
  overflow-x:hidden;max-width:100%;position:relative;z-index:1;
}
/* HERO */
#fuji26 .f-hero{
  position:relative;min-height:100vh;display:flex;flex-direction:column;
  align-items:center;justify-content:center;padding:4rem 2rem 6rem;
  border-bottom:1px solid #E0DDD6;overflow:hidden;
  background:rgba(255,255,255,.7);text-align:center;backdrop-filter:blur(2px);
}
#fuji26 .f-particle{position:absolute;border-radius:50%;pointer-events:none;animation:fuji-float linear infinite}
#fuji26 .f-circle{
  position:absolute;border-radius:50%;border:1px solid rgba(200,16,46,.07);
  top:50%;left:50%;animation:fuji-pulse 6s ease-in-out infinite;pointer-events:none;
}
#fuji26 .f-circle:nth-child(1){width:500px;height:500px}
#fuji26 .f-circle:nth-child(2){width:700px;height:700px;animation-delay:1s;border-color:rgba(200,16,46,.04)}
#fuji26 .f-circle:nth-child(3){width:900px;height:900px;animation-delay:2s;border-color:rgba(200,16,46,.025)}
#fuji26 .f-circle.miku{border-color:rgba(57,197,187,.08);animation-duration:8s}
#fuji26 .f-fuji-svg{position:absolute;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:860px;opacity:.04;pointer-events:none}
#fuji26 .f-miku-watermark{position:absolute;bottom:3rem;right:3rem;opacity:.055;pointer-events:none;animation:fuji-sway 5s ease-in-out infinite;transform-origin:bottom center}
#fuji26 .f-hero-label{font-family:'DM Mono',monospace;font-size:.7rem;letter-spacing:.32em;color:#C8102E;text-transform:uppercase;position:relative;z-index:1;animation:fuji-fadeUp .7s .1s ease both;margin-bottom:1.2rem}
#fuji26 .f-hero-title{font-family:'Shippori Mincho',serif;font-size:clamp(3.2rem,11vw,7.5rem);font-weight:700;letter-spacing:-.02em;line-height:1;position:relative;z-index:1;animation:fuji-fadeUp .7s .25s ease both}
#fuji26 .f-hero-title span{color:#C8102E}
#fuji26 .f-hero-title span::after{content:'';display:block;height:3px;background:linear-gradient(90deg,#39C5BB,transparent);margin-top:2px;border-radius:2px;animation:fuji-fadeIn 1s 1s ease both}
#fuji26 .f-hero-sub{margin-top:1rem;font-size:.95rem;color:#888;letter-spacing:.28em;position:relative;z-index:1;animation:fuji-fadeUp .7s .4s ease both}
#fuji26 .f-hero-date{margin-top:1.2rem;font-family:'DM Mono',monospace;font-size:.8rem;color:#1A1A1A;letter-spacing:.15em;position:relative;z-index:1;animation:fuji-fadeUp .7s .55s ease both}
#fuji26 .f-miku-badge{display:inline-flex;align-items:center;gap:.4rem;margin-top:1rem;padding:.3rem .8rem;border:1px solid rgba(57,197,187,.35);border-radius:2px;font-family:'DM Mono',monospace;font-size:.6rem;letter-spacing:.25em;color:#39C5BB;position:relative;z-index:1;animation:fuji-fadeUp .7s .65s ease both;background:rgba(57,197,187,.04)}
#fuji26 .f-countdown-wrap{margin-top:2.5rem;position:relative;z-index:1;animation:fuji-fadeUp .7s .7s ease both}
#fuji26 .f-cd-label{font-family:'DM Mono',monospace;font-size:.6rem;letter-spacing:.38em;color:#888;text-transform:uppercase;margin-bottom:.9rem}
#fuji26 .f-countdown{display:flex;gap:1.2rem;align-items:flex-end;justify-content:center;flex-wrap:wrap}
#fuji26 .f-cb{display:flex;flex-direction:column;align-items:center;gap:.25rem}
#fuji26 .f-num{font-family:'Shippori Mincho',serif;font-size:clamp(2.2rem,7vw,4rem);font-weight:700;line-height:1;color:#C8102E;min-width:2ch;text-align:center;transition:color .3s}
#fuji26 .f-unit{font-family:'DM Mono',monospace;font-size:.55rem;letter-spacing:.22em;color:#888;text-transform:uppercase}
#fuji26 .f-sep{font-family:'Shippori Mincho',serif;font-size:2.5rem;color:#E0DDD6;line-height:1;padding-bottom:.4rem}
#fuji26 .f-scroll{position:absolute;bottom:1.8rem;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:.4rem;font-family:'DM Mono',monospace;font-size:.52rem;letter-spacing:.35em;color:#888;text-transform:uppercase;animation:fuji-fadeUp 1s 1.3s ease both;z-index:1}
#fuji26 .f-scroll-line{width:1px;height:36px;background:linear-gradient(to bottom,#39C5BB,transparent);animation:fuji-scrollLine 1.6s ease-in-out infinite}
#fuji26 .f-jp-border{height:4px;background:repeating-linear-gradient(90deg,#C8102E 0,#C8102E 6px,#39C5BB 6px,#39C5BB 10px,transparent 10px,transparent 18px);opacity:.18}
#fuji26 .f-section-label{font-family:'DM Mono',monospace;font-size:.62rem;letter-spacing:.42em;color:#C8102E;text-transform:uppercase;display:flex;align-items:center;gap:1rem;margin-bottom:2rem;position:relative;overflow:hidden}
#fuji26 .f-section-label::after{content:'';flex:1;height:1px;background:linear-gradient(90deg,#E0DDD6,#39C5BB22)}
/* NOTICES */
#fuji26 .f-notices{background:rgba(245,243,238,.88);padding:4rem 2rem;border-bottom:1px solid #E0DDD6;backdrop-filter:blur(4px)}
#fuji26 .f-notices-inner{max-width:900px;margin:0 auto}
#fuji26 .f-notices-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:1.4rem}
#fuji26 .f-ncard{background:rgba(255,255,255,.92);border:1px solid #E0DDD6;padding:1.4rem;position:relative;animation:fuji-cardIn .6s ease both;transition:transform .25s ease,box-shadow .25s ease;overflow:hidden}
#fuji26 .f-ncard::before{content:'';position:absolute;top:0;left:0;width:3px;height:100%;background:linear-gradient(to bottom,#C8102E,#39C5BB)}
#fuji26 .f-ncard:hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(0,0,0,.07)}
#fuji26 .f-ndate{font-family:'DM Mono',monospace;font-size:.72rem;color:#C8102E;letter-spacing:.1em;margin-bottom:.4rem}
#fuji26 .f-ntitle{font-family:'Shippori Mincho',serif;font-size:1rem;font-weight:700;margin-bottom:.3rem;color:#1A1A1A}
#fuji26 .f-ndesc{font-size:.78rem;color:#888;line-height:1.6}
/* TIMELINE */
#fuji26 .f-tl-section{padding:5rem 2rem;max-width:1000px;margin:0 auto}
#fuji26 .f-day{margin-bottom:5rem;animation:fuji-fadeUp .7s ease both}
#fuji26 .f-day-header{display:flex;align-items:flex-end;gap:1.5rem;margin-bottom:2rem;padding-bottom:1.2rem;border-bottom:1px solid #E0DDD6;position:relative}
#fuji26 .f-day-header::after{content:'';position:absolute;bottom:-1px;left:0;width:48px;height:2px;background:#39C5BB;border-radius:2px}
#fuji26 .f-day-num{font-family:'Shippori Mincho',serif;font-size:clamp(3.5rem,9vw,6rem);font-weight:700;line-height:1;color:#E0DDD6;letter-spacing:-.03em;transition:color .3s}
#fuji26 .f-day:hover .f-day-num{color:rgba(57,197,187,.25)}
#fuji26 .f-day-info{flex:1}
#fuji26 .f-day-date{font-family:'DM Mono',monospace;font-size:.68rem;color:#C8102E;letter-spacing:.25em;margin-bottom:.2rem}
#fuji26 .f-day-theme{font-family:'Shippori Mincho',serif;font-size:1.3rem;font-weight:700;color:#1A1A1A}
#fuji26 .f-day-cin{margin-top:.55rem;font-family:'Shippori Mincho',serif;font-size:clamp(1.05rem,3vw,1.45rem);font-weight:700;color:#1A1A1A;letter-spacing:.02em;line-height:1.3}
#fuji26 .f-day-cin-en{font-family:'DM Mono',monospace;font-size:.62rem;letter-spacing:.3em;color:#39C5BB;text-transform:uppercase;margin-top:.2rem;opacity:.85}
#fuji26 .f-yuru-block{margin:.8rem 0 0;padding:.7rem .9rem;border-left:2px solid #39C5BB;background:rgba(57,197,187,.04);border-radius:0 3px 3px 0;font-size:.73rem;color:#555;line-height:1.65}
#fuji26 .f-yuru-block strong{font-family:'Shippori Mincho',serif;color:#39C5BB;font-size:.78rem}
#fuji26 .f-timeline{position:relative;padding-left:2.2rem}
#fuji26 .f-timeline::before{content:'';position:absolute;left:5px;top:8px;bottom:0;width:2px;background:linear-gradient(to bottom,#C8102E 0%,#39C5BB 35%,rgba(57,197,187,.4) 65%,rgba(224,221,214,.3) 100%);border-radius:2px;animation:fuji-lineFlow 4s ease-in-out infinite}
#fuji26 .f-timeline::after{content:'';position:absolute;left:5px;top:8px;bottom:0;width:2px;background:linear-gradient(to bottom,transparent 0%,rgba(255,255,255,.8) 40%,transparent 55%);background-size:100% 60px;animation:fuji-lineScan 2.5s linear infinite;pointer-events:none}
#fuji26 .f-tl-item{position:relative;margin-bottom:1.8rem;animation:fuji-slideRight .5s ease both;padding:.6rem .8rem;border-radius:3px;transition:background .25s ease,transform .2s ease;border-left:2px solid transparent;cursor:pointer}
#fuji26 .f-tl-item:hover{background:rgba(57,197,187,.05);border-left-color:rgba(57,197,187,.3);transform:translateX(3px)}
#fuji26 .f-dot{position:absolute;left:calc(-2.2rem - 1px);top:11px;width:12px;height:12px;border-radius:50%;background:#fff;border:2px solid #C8102E;transition:background .2s,transform .25s,border-color .2s}
#fuji26 .f-dot.major{background:#C8102E;width:14px;height:14px;top:10px;animation:fuji-dotGlow 2.5s ease-in-out infinite}
#fuji26 .f-tl-item:hover .f-dot{background:#39C5BB;border-color:#39C5BB;transform:scale(1.35)}
#fuji26 .f-tl-item:hover .f-dot.major{background:#39C5BB;border-color:#39C5BB}
#fuji26 .f-time{font-family:'DM Mono',monospace;font-size:.63rem;color:#888;letter-spacing:.1em;margin-bottom:.15rem}
#fuji26 .f-name{font-family:'Shippori Mincho',serif;font-size:.98rem;font-weight:700;color:#1A1A1A;margin-bottom:.15rem;transition:color .2s}
#fuji26 .f-desc{font-size:.77rem;color:#888;line-height:1.65}
#fuji26 .f-tag{display:inline-block;font-family:'DM Mono',monospace;font-size:.56rem;letter-spacing:.15em;padding:.12rem .45rem;border:1px solid #E0DDD6;color:#888;margin-top:.3rem;margin-right:.3rem;text-transform:uppercase;transition:border-color .2s,color .2s}
#fuji26 .f-tl-item:hover .f-tag{border-color:rgba(57,197,187,.3)}
#fuji26 .f-tag.red{border-color:#C8102E;color:#C8102E}
/* BUDGET */
#fuji26 .f-budget{background:rgba(245,243,238,.9);padding:5rem 2rem;border-top:1px solid #E0DDD6;backdrop-filter:blur(4px)}
#fuji26 .f-budget-inner{max-width:900px;margin:0 auto}
#fuji26 .f-budget-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(175px,1fr));gap:1.4rem}
#fuji26 .f-bcard{background:rgba(255,255,255,.92);border:1px solid #E0DDD6;padding:1.4rem;animation:fuji-cardIn .6s ease both;transition:transform .22s ease,box-shadow .22s ease;cursor:default;overflow:hidden;position:relative}
#fuji26 .f-bcard:hover{transform:translateY(-4px) rotate(.4deg);box-shadow:0 10px 28px rgba(0,0,0,.07)}
#fuji26 .f-blabel{font-family:'DM Mono',monospace;font-size:.6rem;letter-spacing:.25em;color:#888;text-transform:uppercase;margin-bottom:.6rem}
#fuji26 .f-bamt{font-family:'Shippori Mincho',serif;font-size:1.9rem;font-weight:700;color:#1A1A1A;line-height:1}
#fuji26 .f-bamt small{font-size:.8rem;font-family:'DM Mono',monospace;color:#888;font-weight:400}
#fuji26 .f-btotal{margin-top:1.5rem;padding:1.8rem 2rem;background:linear-gradient(105deg,#C8102E 0%,#a50e24 100%);color:#fff;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;animation:fuji-cardIn .6s .4s ease both;position:relative;overflow:hidden}
#fuji26 .f-btotal-label{font-family:'DM Mono',monospace;font-size:.7rem;letter-spacing:.25em;text-transform:uppercase;opacity:.75}
#fuji26 .f-btotal-amt{font-family:'Shippori Mincho',serif;font-size:2.3rem;font-weight:700}
/* GEAR */
#fuji26 .f-gear{padding:5rem 2rem;max-width:900px;margin:0 auto}
#fuji26 .f-gear-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(175px,1fr));border:1px solid #E0DDD6;margin-top:2rem;animation:fuji-cardIn .6s .1s ease both}
#fuji26 .f-gcol{padding:1.4rem;border-right:1px solid #E0DDD6;transition:background .2s}
#fuji26 .f-gcol:hover{background:rgba(57,197,187,.03)}
#fuji26 .f-gcol:last-child{border-right:none}
#fuji26 .f-gcol-title{font-family:'DM Mono',monospace;font-size:.6rem;letter-spacing:.25em;color:#39C5BB;text-transform:uppercase;margin-bottom:.9rem}
#fuji26 .f-gitem{font-size:.77rem;color:#1A1A1A;padding:.2rem 0;border-bottom:1px solid #E0DDD6;line-height:1.5}
#fuji26 .f-gitem:last-child{border-bottom:none}
/* FOOTER */
#fuji26 .f-footer{border-top:1px solid #E0DDD6;padding:2rem;text-align:center;font-family:'DM Mono',monospace;font-size:.62rem;letter-spacing:.2em;color:#888;position:relative;background:rgba(255,255,255,.88)}
#fuji26 .f-footer span{color:#C8102E}
#fuji26 .f-footer-miku{color:#39C5BB;font-size:.58rem;margin-top:.5rem;opacity:.65;letter-spacing:.3em}
/* EQ */
#fuji-eq span:nth-child(1){animation:fuji-eq1 .9s ease-in-out infinite}
#fuji-eq span:nth-child(2){animation:fuji-eq2 .75s ease-in-out infinite .1s}
#fuji-eq span:nth-child(3){animation:fuji-eq3 1.1s ease-in-out infinite .2s}
#fuji-eq span:nth-child(4){animation:fuji-eq4 .85s ease-in-out infinite .05s}
#fuji-eq span:nth-child(5){animation:fuji-eq5 1s ease-in-out infinite .15s}
#fuji-eq.paused span{animation-play-state:paused;height:4px!important}
/* Leaflet */
.leaflet-container{background:#f5f3ee}
.leaflet-tooltip{background:rgba(255,255,255,.95)!important;border:1px solid #E0DDD6!important;border-radius:3px!important;box-shadow:0 4px 12px rgba(0,0,0,.1)!important;padding:4px 8px!important}
/* POPUP */
.fuji-anime-overlay{position:fixed;inset:0;z-index:99999;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,.55);backdrop-filter:blur(6px);animation:fuji-fadeIn .3s ease;padding:1rem}
.fuji-anime-popup{background:#fff;border-radius:4px;overflow:hidden;max-width:440px;width:100%;box-shadow:0 24px 64px rgba(0,0,0,.3);animation:fuji-bubbleIn .35s ease;position:relative}
/* LEGEND */
#fuji-legend{position:fixed;top:1rem;left:1rem;z-index:100;background:rgba(255,255,255,.94);border:1px solid #E0DDD6;border-radius:4px;padding:.5rem .6rem;box-shadow:0 4px 20px rgba(0,0,0,.1);backdrop-filter:blur(8px);min-width:140px;max-width:180px}
#fuji-legend-header{display:flex;align-items:center;justify-content:space-between;cursor:pointer;gap:.5rem}
#fuji-legend-title{font-family:'DM Mono',monospace;font-size:.48rem;letter-spacing:.2em;color:#888;text-transform:uppercase}
#fuji-legend-arr{font-size:.5rem;color:#aaa;transition:transform .3s ease}
#fuji-legend-arr.open{transform:rotate(180deg)}
#fuji-legend-body{max-height:0;overflow:hidden;transition:max-height .35s ease,opacity .35s ease;opacity:0}
#fuji-legend-body.open{max-height:300px;opacity:1}
.legend-item{display:flex;align-items:center;gap:.3rem;margin-top:.25rem}
.legend-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.legend-label{font-family:'DM Mono',monospace;font-size:.48rem;color:#444;letter-spacing:.05em}
/* MUSIC */
#fuji-music-bubble{position:fixed;bottom:1.8rem;right:1.8rem;z-index:9999}
#fuji-music-pill{display:flex;align-items:center;gap:.7rem;padding:.65rem 1rem .65rem .75rem;background:linear-gradient(135deg,#1d9e97 0%,#39C5BB 100%);border-radius:50px;box-shadow:0 4px 20px rgba(57,197,187,.4),0 2px 8px rgba(0,0,0,.12);cursor:pointer;white-space:nowrap;overflow:hidden;max-width:240px}
/* SPINNER */
.fuji-spin{width:16px;height:16px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:fuji-spin .8s linear infinite;display:inline-block;flex-shrink:0}
/* RESPONSIVE */
@media(max-width:600px){
  #fuji26 .f-day-header{flex-direction:column;align-items:flex-start;gap:.5rem}
  #fuji26 .f-day-num{font-size:3rem}
  #fuji26 .f-gcol{border-right:none;border-bottom:1px solid #E0DDD6}
  #fuji26 .f-btotal{flex-direction:column;text-align:center}
  #fuji26 .f-countdown{gap:.7rem}
  #fuji26 .f-sep{font-size:1.8rem}
  .fuji-anime-popup{max-width:100%}
}
</style>
</head>
<body>
<!-- Map background -->
<div id="fuji-map-bg" style="position:fixed;inset:0;z-index:0;opacity:.22;pointer-events:none;filter:saturate(.7)"></div>

<!-- Particle canvas -->
<canvas id="fuji-miku-canvas" style="position:fixed;inset:0;width:100%;height:100%;pointer-events:none;z-index:99998"></canvas>

<!-- Legend -->
<div id="fuji-legend">
  <div id="fuji-legend-header" onclick="toggleLegend()">
    <span id="fuji-legend-title">🗺️ 聖地巡禮 Map</span>
    <span id="fuji-legend-arr">▼</span>
  </div>
  <div id="fuji-legend-body">
    <div class="legend-item"><div class="legend-dot" style="background:#39C5BB"></div><span class="legend-label">🏕️ ゆるキャン△ S1</span></div>
    <div class="legend-item"><div class="legend-dot" style="background:#2eaadb"></div><span class="legend-label">🏕️ ゆるキャン△ S2</span></div>
    <div class="legend-item"><div class="legend-dot" style="background:#f76e3c"></div><span class="legend-label">⛰️ 向山進発NS</span></div>
    <div class="legend-item"><div class="legend-dot" style="background:#e06fa0"></div><span class="legend-label">🌸 薫る花は凛と</span></div>
    <div class="legend-item"><div class="legend-dot" style="background:#c0392b"></div><span class="legend-label">🔫 Lycoris Recoil</span></div>
    <div class="legend-item"><div class="legend-dot" style="background:#8e44ad"></div><span class="legend-label">🎸 BanG Dream MyGO</span></div>
    <div class="legend-item"><div class="legend-dot" style="background:#1c398e"></div><span class="legend-label">🐇 青春豬頭少年</span></div>
    <div class="legend-item"><div class="legend-dot" style="background:#ff428e"></div><span class="legend-label">🎸 孤獨搖滾</span></div>
  </div>

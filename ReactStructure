    zoomControl:false, attributionControl:false,
    dragging:false, scrollWheelZoom:false,
    doubleClickZoom:false, touchZoom:false, keyboard:false,
  });
  L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
    subdomains:'abcd', maxZoom:19,
  }).addTo(mapInstance);
  markersLayer = L.layerGroup().addTo(mapInstance);
  renderMarkers();
}

function flyMap(lat, lng, zoom) {
  if (!mapInstance) return;
  mapInstance.flyTo([lat, lng], zoom, { animate:true, duration:1.2 });
}

function renderMarkers() {
  if (!markersLayer) return;
  markersLayer.clearLayers();
  allPoints.forEach(pt => {
    if (!pt.geo || pt.geo.length < 2) return;
    const svg = `<svg width="20" height="20" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><circle cx="10" cy="10" r="7" fill="${pt.animeColor}" fill-opacity="0.85" stroke="white" stroke-width="2"/><circle cx="10" cy="10" r="2.5" fill="white"/></svg>`;
    const icon = L.divIcon({ className:'', html:svg, iconSize:[20,20], iconAnchor:[10,10] });
    const m = L.marker([pt.geo[0], pt.geo[1]], { icon });
    m.bindTooltip(`<span style="font-family:'DM Mono',monospace;font-size:.6rem;color:${pt.animeColor}">${pt.animeEmoji} ${pt.cn||pt.name}</span>`, { permanent:false, direction:'top', offset:[0,-8] });
    markersLayer.addLayer(m);
  });
}

// ═══════════════════════════════════════════
// FETCH ANIME POINTS (background)
// ═══════════════════════════════════════════
async function fetchAnimePoints() {
  for (const anime of ANIME_LIST) {
    try {
      const res = await fetch(`https://api.anitabi.cn/bangumi/${anime.id}/points/detail?haveImage=true`, {
        signal: AbortSignal.timeout(8000)
      });
      if (!res.ok) continue;
      const data = await res.json();
      if (!Array.isArray(data)) continue;
      const newPts = data
        .filter(pt => pt.geo && pt.image)
        .map(pt => ({
          ...pt,
          animeId: anime.id,
          animeName: anime.name,
          animeCn: anime.nameCn,
          animeColor: anime.color,
          animeEmoji: anime.emoji,
        }));
      // Merge, avoiding duplicates by id
      const existingIds = new Set(allPoints.map(p => p.id));
      const fresh = newPts.filter(p => !existingIds.has(p.id));
      allPoints = allPoints.concat(fresh);
      renderMarkers();
    } catch(e) { /* silently ignore */ }
  }
}

// ═══════════════════════════════════════════
// DESTINATION CLICK HANDLER
// ═══════════════════════════════════════════
function handleDest(lat, lng, day) {
  activeDay = day;
  flyMap(lat, lng, 14);
  updateDestButtons();

  // Detect within 1km
  const nearby = allPoints
    .map(pt => ({ point: pt, distance: haversine(lat, lng, pt.geo[0], pt.geo[1]) }))
    .filter(r => r.distance <= 1000)
    .sort((a,b) => a.distance - b.distance)
    .slice(0, 10);

  if (nearby.length > 0) {
    showPopup(nearby, 0);
  }
}

// ═══════════════════════════════════════════
// POPUP
// ═══════════════════════════════════════════
function showPopup(results, idx) {
  popupResults = results;
  popupIdx = idx;
  renderPopup();
  document.getElementById('fuji-popup-overlay').style.display = 'flex';
}

function closePopup() {
  document.getElementById('fuji-popup-overlay').style.display = 'none';
}

function renderPopup() {
  if (!popupResults.length) return;
  const { point, distance } = popupResults[popupIdx];
  const distStr = distance < 1000 ? `${Math.round(distance)}m` : `${(distance/1000).toFixed(1)}km`;
  const imgSrc = point.image ? point.image.replace('?plan=h160','?plan=h360') : '';
  const label = point.cn || point.name;
  const nav = popupResults.length > 1 ? `
    <div style="border-top:1px solid #E0DDD6;padding:.6rem 1rem;display:flex;align-items:center;justify-content:space-between">
      <span style="font-family:'DM Mono',monospace;font-size:.55rem;color:#888;letter-spacing:.12em">${popupIdx+1} / ${popupResults.length} 附近聖地</span>
      <div style="display:flex;gap:.4rem">
        <button onclick="navPopup(-1)" ${popupIdx===0?'disabled':''} style="font-family:'DM Mono',monospace;font-size:.58rem;padding:.2rem .6rem;border:1px solid #E0DDD6;background:#fff;cursor:pointer;opacity:${popupIdx===0?.4:1};border-radius:2px">← Prev</button>
        <button onclick="navPopup(1)" ${popupIdx===popupResults.length-1?'disabled':''} style="font-family:'DM Mono',monospace;font-size:.58rem;padding:.2rem .6rem;border:1px solid #E0DDD6;background:#fff;cursor:pointer;opacity:${popupIdx===popupResults.length-1?.4:1};border-radius:2px">Next →</button>
      </div>
    </div>` : '';

  const popup = document.getElementById('fuji-popup-overlay');
  popup.innerHTML = `
    <div class="fuji-anime-popup" style="border:2px solid ${point.animeColor}" onclick="event.stopPropagation()">
      <div style="padding:.7rem 1rem;background:${point.animeColor};display:flex;align-items:center;justify-content:space-between">
        <div style="display:flex;align-items:center;gap:.5rem">
          <span style="font-size:1.2rem">${point.animeEmoji}</span>
          <div>
            <div style="font-family:'DM Mono',monospace;font-size:.55rem;letter-spacing:.22em;color:rgba(255,255,255,.8);text-transform:uppercase">聖地巡禮 · ${distStr} away</div>
            <div style="font-family:'Shippori Mincho',serif;font-size:.88rem;font-weight:700;color:#fff">${point.animeName} · ${point.animeCn}</div>
          </div>
        </div>
        <button onclick="closePopup()" style="background:rgba(255,255,255,.2);border:none;color:#fff;width:28px;height:28px;border-radius:50%;cursor:pointer;font-size:1rem;display:flex;align-items:center;justify-content:center;flex-shrink:0">×</button>
      </div>
      ${imgSrc ? `
      <div style="position:relative;background:#111;aspect-ratio:16/9;overflow:hidden;max-height:240px">
        <img src="${imgSrc}" alt="${label}" style="width:100%;height:100%;object-fit:cover;display:block" onerror="this.parentElement.style.display='none'">
        ${point.ep ? `<div style="position:absolute;top:.5rem;right:.5rem;background:rgba(0,0,0,.7);color:#fff;font-family:'DM Mono',monospace;font-size:.55rem;letter-spacing:.12em;padding:.2rem .5rem;border-radius:2px">EP ${point.ep}</div>` : ''}
      </div>` : ''}
      <div style="padding:.9rem 1rem">
        <div style="font-family:'Shippori Mincho',serif;font-size:1rem;font-weight:700;color:#1A1A1A;margin-bottom:.25rem">${label}</div>
        ${point.cn && point.name !== point.cn ? `<div style="font-family:'DM Mono',monospace;font-size:.62rem;color:#888;letter-spacing:.08em;margin-bottom:.25rem">${point.name}</div>` : ''}
        <div style="font-family:'DM Mono',monospace;font-size:.58rem;color:${point.animeColor};letter-spacing:.12em;display:flex;align-items:center;gap:.4rem;flex-wrap:wrap">
          <span>📍 ${distStr} from destination</span>
          ${point.ep ? `<span>· Episode ${point.ep}</span>` : ''}
        </div>
        ${point.origin ? `<div style="margin-top:.4rem;font-family:'DM Mono',monospace;font-size:.5rem;color:#aaa;letter-spacing:.1em">圖片來源: ${point.origin}</div>` : ''}
      </div>
      ${nav}
    </div>`;
  popup.onclick = closePopup;
  popup.querySelector('.fuji-anime-popup').onclick = e => e.stopPropagation();
}

function navPopup(dir) {
  popupIdx = Math.max(0, Math.min(popupResults.length-1, popupIdx+dir));
  renderPopup();
}

// ═══════════════════════════════════════════
// DEST BUTTONS
// ═══════════════════════════════════════════
function buildDestButtons() {
  const container = document.getElementById('dest-buttons');
  if (!container) return;
  container.innerHTML = DESTINATIONS.map((d,i) => `
    <button id="db-${i}" onclick="handleDest(${d.lat},${d.lng},${d.day})" style="
      font-family:'DM Mono',monospace;font-size:.55rem;letter-spacing:.1em;
      padding:.25rem .6rem;border:1px solid #E0DDD6;
      background:#fff;color:#666;cursor:pointer;border-radius:2px;transition:all .2s;
    ">D${d.day} ${d.name}</button>
  `).join('');
}

function updateDestButtons() {
  DESTINATIONS.forEach((d,i) => {
    const btn = document.getElementById(`db-${i}`);
    if (!btn) return;
    const active = activeDay === d.day;
    btn.style.border = `1px solid ${active ? DAY_COLORS[d.day] : '#E0DDD6'}`;
    btn.style.background = active ? `${DAY_COLORS[d.day]}10` : '#fff';
    btn.style.color = active ? DAY_COLORS[d.day] : '#666';
  });
}

// ═══════════════════════════════════════════
// LEGEND TOGGLE
// ═══════════════════════════════════════════
function toggleLegend() {
  const body = document.getElementById('fuji-legend-body');
  const arr  = document.getElementById('fuji-legend-arr');

// ═══════════════════════════════════════════
// COUNTDOWN
// ═══════════════════════════════════════════
function startCountdown() {
  const pad = n => (n<10?'0':'')+n;
  function tick() {
    const target = new Date('2026-07-08T00:55:00+08:00').getTime();
    const diff = target - Date.now();
    const set = (id,v) => { const e=document.getElementById(id); if(e) e.textContent=v; };
    if (diff<=0) { ['fuji-days','fuji-hours','fuji-mins','fuji-secs'].forEach(id=>set(id,'00')); return; }
    set('fuji-days',  pad(Math.floor(diff/86400000)));
    set('fuji-hours', pad(Math.floor((diff%86400000)/3600000)));
    set('fuji-mins',  pad(Math.floor((diff%3600000)/60000)));
    set('fuji-secs',  pad(Math.floor((diff%60000)/1000)));
  }
  tick();
  setInterval(tick, 1000);
}

// ═══════════════════════════════════════════
// MUSIC
// ═══════════════════════════════════════════
let _audio = null, _playing = false;
function fujiTogglePlay() {
  if (!_audio) {
    _audio = new Audio('https://raw.githubusercontent.com/SamuelYuen0201/26inMt-Fuji/main/miku_hajimarinomirai_256kbps.mp3');
    _audio.loop = true;
    _audio.volume = 0.72;
  }
  const eq = document.getElementById('fuji-eq');
  const ico = document.getElementById('fuji-play-icon');
  if (!_playing) {
    _audio.play().then(() => {
      _playing = true;
      if (eq) eq.classList.remove('paused');
      if (ico) ico.innerHTML = '<rect x="1.5" y="1" width="2.8" height="8" rx="1" fill="white"/><rect x="5.7" y="1" width="2.8" height="8" rx="1" fill="white"/>';
    }).catch(()=>{});
  } else {
    _audio.pause();
    _playing = false;
    if (eq) eq.classList.add('paused');
    if (ico) ico.innerHTML = '<polygon points="2,1 9,5 2,9" fill="white"/>';
  }
}

// ═══════════════════════════════════════════
// CURSOR PARTICLES
// ═══════════════════════════════════════════
(function() {
  const canvas = document.getElementById('fuji-miku-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  let running = true;
  const resize = () => { canvas.width = window.innerWidth; canvas.height = window.innerHeight; };
  resize();
  window.addEventListener('resize', resize);
  const particles = [];
  const mouse = { x:-999, y:-999, vx:0, vy:0 };
  const COLORS = ['rgba(57,197,187,','rgba(100,220,215,','rgba(200,240,238,','rgba(255,255,255,','rgba(180,240,235,'];
  function create(x,y,vx,vy) {
    const count = Math.min(Math.floor(Math.sqrt(vx*vx+vy*vy)*.4)+1,4);
    for(let i=0;i<count;i++){
      const a=Math.random()*Math.PI*2, s=1.5+Math.random()*5;
      particles.push({
        x:x+(Math.random()-.5)*10, y:y+(Math.random()-.5)*10,
        vx:Math.cos(a)*(.3+Math.random()*1.5)+vx*.08, vy:Math.sin(a)*(.3+Math.random()*1.5)+vy*.08-Math.random()*.7,
        life:1, decay:.012+Math.random()*.018, size:s, maxSize:s,
        color:COLORS[Math.floor(Math.random()*COLORS.length)], rotation:Math.random()*Math.PI*2, rotSpeed:(Math.random()-.5)*.12,
      });
    }
  }
  let lastEmit=0;
  function update(ts) {
    if(!running) return;
    ctx.clearRect(0,0,canvas.width,canvas.height);
    if(mouse.x>0){
      const g=ctx.createRadialGradient(mouse.x,mouse.y,0,mouse.x,mouse.y,20);
      g.addColorStop(0,'rgba(57,197,187,.3)'); g.addColorStop(1,'rgba(57,197,187,0)');
      ctx.beginPath(); ctx.arc(mouse.x,mouse.y,20,0,Math.PI*2); ctx.fillStyle=g; ctx.fill();
    }
    const speed=Math.sqrt(mouse.vx**2+mouse.vy**2);
    if(ts-lastEmit>(speed>3?18:40)&&speed>.5){create(mouse.x,mouse.y,mouse.vx,mouse.vy);lastEmit=ts;}
    for(let i=particles.length-1;i>=0;i--){
      const p=particles[i];
      p.x+=p.vx; p.y+=p.vy; p.vy+=.018; p.vx*=.97; p.vy*=.97;
      p.life-=p.decay; p.rotation+=p.rotSpeed; p.size=p.maxSize*p.life;
      if(p.life<=0){particles.splice(i,1);continue;}
      ctx.save(); ctx.translate(p.x,p.y); ctx.rotate(p.rotation);
      ctx.globalAlpha=p.life; ctx.fillStyle=p.color+p.life+')';
      ctx.beginPath(); ctx.arc(0,0,p.size,0,Math.PI*2); ctx.fill(); ctx.restore();
    }
    requestAnimationFrame(update);
  }
  const onMove = e=>{mouse.vx=e.clientX-mouse.x;mouse.vy=e.clientY-mouse.y;mouse.x=e.clientX;mouse.y=e.clientY;};
  const onTouch= e=>{const t=e.touches[0];mouse.vx=t.clientX-mouse.x;mouse.vy=t.clientY-mouse.y;mouse.x=t.clientX;mouse.y=t.clientY;};
  document.addEventListener('mousemove',onMove);
  document.addEventListener('touchmove',onTouch,{passive:true});
  requestAnimationFrame(update);
})();

// ═══════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════
window.addEventListener('DOMContentLoaded', function() {
  initMap();
  startCountdown();
  buildDestButtons();
  fetchAnimePoints();
});
</script>
